meta {
  name: 8. Update Product
  type: http
  seq: 8
}

put {
  url: {{catalog_url}}/api/v1/products/{{product_id}}
  body: json
  auth: none
}

body:json {
  {
    "name": "Salmon Roll Premium x8",
