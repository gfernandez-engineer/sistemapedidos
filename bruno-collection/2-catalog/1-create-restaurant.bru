meta {
  name: 1. Create Restaurant
  type: http
  seq: 1
}

post {
  url: {{catalog_url}}/api/v1/restaurants
  body: json
  auth: none
}

body:json {
  {
    "name": "Sushi Master",
    "description": "Autentica cocina japonesa con ingredientes frescos",
    "address": "Av. Isidora Goyenechea 3000, Las Condes",
    "phone": "+56223456789",
    "cuisineType": "JAPANESE"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("restaurant_id", res.body.id);
  }
}
