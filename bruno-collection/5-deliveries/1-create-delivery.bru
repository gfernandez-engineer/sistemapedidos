meta {
  name: 1. Create Delivery
  type: http
  seq: 1
}

post {
  url: {{deliveries_url}}/api/v1/deliveries
  body: json
  auth: none
}

body:json {
  {
    "orderId": "{{order_id}}",
    "deliveryAddress": "Av. Las Condes 5678, Santiago"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("delivery_id", res.body.id);
  }
}
