meta {
  name: 1. Register Driver
  type: http
  seq: 1
}

post {
  url: {{deliveries_url}}/api/v1/drivers
  body: json
  auth: none
}

body:json {
  {
    "name": "Carlos Rodriguez",
    "phone": "+56911223344",
    "vehicleType": "MOTORCYCLE"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("driver_id", res.body.id);
  }
}
