meta {
  name: 1. Process Payment
  type: http
  seq: 1
}

post {
  url: {{payments_url}}/api/v1/payments
  body: json
  auth: none
}

body:json {
  {
    "orderId": "{{order_id}}",
    "userId": "{{user_id}}",
    "amount": 29980,
    "paymentMethod": "CREDIT_CARD"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("payment_id", res.body.id);
  }
}
